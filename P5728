#include <bits/stdc++.h>
using namespace std;
int main()
{
    int n,a[1000],b[1000],c[1000],d[1000],count=0;
    cin>>n;
    for(int i=0;i<n;i++)
    {
        cin>>a[i]>>b[i]>>c[i];
        d[i]=a[i]+b[i]+c[i];
    }
    for(int i=0;i<n;i++)
    {
        for(int j=i+1;j<n;j++)
        {
            if((abs(a[i]-a[j])<=5)&&(abs(b[i]-b[j])<=5)&&(abs(c[i]-c[j])<=5)&&(abs(d[i]-d[j])<=10))
            {
                count++;
            }
        }
    }
    printf("%d",count);
}
