#include<bits/stdc++.h>
using namespace std;
int main(){
	ios::sync_with_stdio(0),cin.tie(0),cout.tie(0);//缩短输入输出时间
	long long a,b;
	cin>>a>>b;

	for(int i=a;i<=b;i++){
		if(i%2==0){//特判偶数
			continue;//跳过偶数
		}

		int w=i,s=0;
		while(w!=0){//判断是否为回文数
			s=s*10+w%10;
			w/=10;
		}
		if(s!=i){
			continue;
		}//不是回文跳过

		int f=0;//再判断是否为质数
		for(int j=2;j*j<=i;j++){
			if(i%j==0){
				f=1;
				break;
			}
		}
		if(f==0){
			cout<<i<<endl;
		}
	}
	
}
