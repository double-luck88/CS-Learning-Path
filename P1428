#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n,m,count=0,x;
    vector<int>arr;
    cin>>n;
    m=n;
    while(m--)
    {
        cin>>x;
        arr.push_back(x);
    }
    for(int i=0;i<n;i++)
    {
        count=0;
        for(int j=0;j<i;j++)
        {
            if(arr[j]<arr[i])
            {
                count++;
            }
        }
        cout<<count<<' ';
    }
    
}
