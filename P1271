#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n,m,x;
    cin>>n>>m;//n没啥用
    vector<int>arr;
    for(int i=0;i<m;i++)
    {
        cin>>x;
        arr.push_back(x);//把输入的x放入动态数组里面
    }
    sort(arr.begin(),arr.end());//用sort函数排序
    for(auto ele:arr)
    {
        cout<<ele<<' ';
    }
   
}
