#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n;
    cin>>n;
    vector<int>arr;
    arr.push_back(n);
    while(n!=1)
    {
        if(n%2==0)
        {
            n/=2;
            
        }
        else
        {
            n=n*3+1;
        }
        arr.push_back(n);
    }
    reverse(arr.begin(),arr.end());
    for(auto ele: arr)
    {
        cout<<ele<<' ';
    }
}
