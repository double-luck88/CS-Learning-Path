list1=[]
def func(i):
    if i<2:
        return False
    for j in range(2,int(i**0.5)+1):
        if i%j==0:
            return False
    return True
def isGDBH(n):
    for i in range(2,n//2+1):
        if func(i) and func(n-i):
            list1.append(f'{n}={i}+{n-i}')
    return list1
n=int(input('请输入一个正整数：'))
list1=isGDBH(n)
print(list1)
