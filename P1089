#include<bits/stdc++.h>
using namespace std;
int main()
{
    int x,n;
    vector<int>arr;
    for(int i=0;i<12;i++)
    {
        cin>>x;
        arr.push_back(x);
    }
    int s=0;
    double count=0;
    for(int i=0;i<12;i++)
    {
        s=300+s-arr[i];
        if(s>=100)
        {
            n=s;
            s=s%100;//只存整百的钱
            count+=n-s;
            //cout<<count<<endl;
        }
        
         //cout<<s<<endl;
        if(s<0)
        {
            cout<<'-'<<i+1;
            return 0;
        }
    }
    cout<<count*(1+0.2)+s;//别忘记加上最后剩余的
    
}
