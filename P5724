#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n,x,max1,min1,a,t;
    vector<int>arr;
    cin>>n;
    t=n;
    while(n--)
    {
        cin>>x;
        arr.push_back(x);
    }
    max1=arr[0];
    for(int i=1;i<t;i++)
    {
        if(arr[i]>max1)
        {
            max1=arr[i];
        }
    }
    min1=arr[0];
    for(int i=1;i<t;i++)
    {
        if(min1>arr[i])
        {
            min1=arr[i];
        }
    }
    a=max1-min1;
    cout<<a;
    
}
