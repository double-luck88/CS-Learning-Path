#include<bits/stdc++.h>
using namespace std;
int main()
{
    int n,a,x,t=0,count=1;
    vector<int>arr;
    cin>>n;
    a=n;
    while(n--)
    {
        cin>>x;
        arr.push_back(x);
    }
    for(int i=0;i<a-1;i++)
    {
        if(arr[i]+1==arr[i+1])//遇到连号就加一
        {
            count+=1;
        }
        if(count>t)//把最大次数赋值给t
        {
            t=count;
        }
        if(arr[i]+1!=arr[i+1])//如果不是连号就重置
        {
            count=1;
        }
        
    }
    cout<<t;
}
